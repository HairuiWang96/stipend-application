# API Key for authenticating requests to /api/applications
# Replace with your own secret key in .env.local
API_KEY=your-secret-api-key-here

# Encryption key for PII data (SSN, DOB)
# Must be a secure random string - will be hashed to 256 bits
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=your-encryption-key-here

# Optional: Public API key (if needed for client-side requests)
# NEXT_PUBLIC_API_KEY=your-public-api-key-here
